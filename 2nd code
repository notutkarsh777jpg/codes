#include <iostream> 
using namespace std; 

class Student
{
private:
int rollNo;
string name;
string div;
float marks[10]; 
float total; 
float percentage; 
int n; 
public:
// Function to accept student details and marks
void getData()
{
// Accept roll number
cout << "\nEnter Roll Number: ";
cin >> rollNo;
cin.ignore();
// Accept name
cout << "\nEnter name: ";
getline(cin, name);
// Accept div
cout << "\nEnter Division: ";
getline(cin, div);
// Accept number of subjects
cout << "Enter number of subjects: ";
cin >> n;
total = 0; 
for (int i = 0; i < n; i++)
{
cout << "Enter marks of subject " << i + 1 << ": ";
cin >> marks[i];
total = total + marks[i];
}
}
// Function to calculate percentage
void calculate()
{
percentage = total / n; 
}
// Function to display student result
void display()
{
cout << "\nRoll Number : " << rollNo;
cout << "\nName: " << name;
cout << "\nDivision: " << div;
cout << "\nTotal Marks : " << total;
cout << "\nPercentage : " << percentage << "%\n";
}
};
// Main function
int main()
{
int stud; 

cout << "Enter number of students: ";
cin >> stud;
Student s[10]; 

for (int i = 0; i < stud; i++)
{
cout << "\n--- Student " << i + 1 << " ---";
s[i].getData(); 
s[i].calculate(); 
s[i].display(); 
}
return 0; 
}
